<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>AAF মাস্টার কন্ট্রোল প্যানেল v9.0</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.6.1/firebase-database-compat.js"></script>
    <style>
        /* ===== মোবাইল ফিক্স (আগের স্টাইলের ওভাররাইড) ===== */
        @media (max-width: 768px) {
            .sidebar { display: none; }
            .main-content { margin-left: 0; width: 100%; padding: 12px; padding-bottom: 70px; }
            .bottom-nav { display: flex; }
            .premium-card { padding: 12px !important; margin-bottom: 12px; }
            .card-title { font-size: 13px !important; }
            input, textarea, select { font-size: 14px !important; padding: 8px 10px !important; }
            .btn-main { padding: 10px !important; font-size: 13px !important; }
            .request-table, .user-table { min-width: 100%; font-size: 12px; }
            .request-table th, .user-table th { padding: 6px 4px; }
            .request-table td, .user-table td { padding: 6px 4px; }
            .row { grid-template-columns: 1fr; gap: 6px; }
            .user-table th:nth-child(6), .user-table td:nth-child(6) { display: none; }
            #member-list-body table { font-size: 10px; min-width: 600px; }
            #member-list-body th, #member-list-body td { padding: 4px 2px; white-space: nowrap; }
            .approve-btn, .reject-btn { padding: 4px 8px; font-size: 10px; }
        }
        @import url('https://fonts.googleapis.com/css2?family=Syncopate:wght@400;700&family=Rajdhani:wght@400;600;700&display=swap');
        :root{--bg:#020617;--card:#0d111c;--border:rgba(0,242,254,0.15);--cyan:#00f2fe;--purple:#7000ff;--accent:#00ff88;--danger:#ff0055;--gold:#ffaa00;--sidebar-width:260px}
        body{background:var(--bg);color:#fff;font-family:'Hind Siliguri',sans-serif;margin:0;overflow-x:hidden}
        .sidebar{width:var(--sidebar-width);background:var(--card);height:100vh;position:fixed;border-right:1px solid var(--border);z-index:100;transition:0.3s}
        .nav-links li.active,.bottom-nav i.active{color:var(--cyan);background:rgba(0,242,254,0.08);border-radius:10px}
        .main-content{margin-left:var(--sidebar-width);width:calc(100% - var(--sidebar-width));min-height:100vh;padding:30px;position:relative;z-index:0}
        .page-section{position:absolute;inset:0;display:none;overflow-y:auto;padding-bottom:100px;background:var(--bg)}
        .page-section.active{display:block}
        .premium-card{background:var(--card);border:1px solid var(--border);border-radius:24px;padding:15px;margin-bottom:15px;overflow-x:auto}
        .card-title{font-size:14px;font-weight:700;margin-bottom:12px;color:var(--cyan);display:flex;align-items:center;gap:6px}
        input,textarea,select{width:100%;background:#000;border:1px solid var(--border);border-radius:14px;padding:8px 12px;margin-bottom:8px;color:#fff;font-size:13px}
        label{font-size:12px;margin-bottom:2px;display:inline-block}
        .btn-main{width:100%;background:linear-gradient(90deg,var(--cyan),var(--purple));border:none;border-radius:14px;padding:10px;margin-top:5px;color:#fff;font-weight:700;cursor:pointer;font-size:12px}
        .row{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:5px}
        .bottom-nav{display:none;position:fixed;bottom:0;left:0;width:100%;background:var(--card);border-top:1px solid var(--border);z-index:1000;justify-content:space-around;padding:6px 0}
        .bottom-nav i{font-size:16px;color:#94a3b8;cursor:pointer}
        .request-table,.user-table{width:100%;border-collapse:collapse}
        .request-table th,.user-table th{background:#1e293b;color:#00f2fe;padding:10px 8px;text-align:left;font-weight:700;border-bottom:2px solid var(--cyan)}
        .request-table td,.user-table td{padding:8px;border-bottom:1px solid #2d3a5e}
        .deposit-row .amount{color:#00ff88;font-weight:700}
        .withdraw-row .amount{color:#ffaa00;font-weight:700}
        .approve-btn{background:#00ff88;color:#000;border:none;padding:6px 12px;border-radius:6px;cursor:pointer;margin-right:5px}
        .reject-btn{background:#ff5555;color:#fff;border:none;padding:6px 12px;border-radius:6px;cursor:pointer}
        .empty-state,.error-state{text-align:center;padding:20px;color:#94a3b8}
        .error-state{color:#ff5555}
        code{background:#000;padding:4px 6px;border-radius:4px;font-size:11px}
        #admin-login-overlay{position:fixed;inset:0;background:var(--bg);z-index:9999;display:flex;justify-content:center;align-items:center}
        table{min-width:500px}
        .user-table td:nth-child(1){font-weight:600;color:#ffaa00}
        .user-table td:nth-child(2){font-family:monospace}
        .user-table td:nth-child(3){color:#a0c4ff}
        .user-table td:nth-child(4){color:#00ff88;font-weight:700}
        .user-table td:nth-child(5){font-size:10px;font-family:monospace;background:rgba(0,242,254,0.05)}
        .user-table td:nth-child(6){text-align:center}
        #member-list-body{overflow-x:auto}
        #member-list-body table{white-space:nowrap}
        button[onclick*="clearField"]{padding:4px 8px!important;font-size:12px!important;margin-top:0!important}
        #admin-task-list div{padding:6px 0!important}
    </style>
</head>
<body>
<div id="admin-login-overlay">
    <div style="background: var(--card); padding: 40px; border-radius: 30px; border: 1px solid var(--cyan); text-align: center; width: 320px;">
        <h2 style="color:var(--cyan)">AAF MASTER CONTROL</h2>
        <input type="password" id="admin-pass" placeholder="Enter PIN" style="text-align: center; font-size: 24px;">
        <button class="btn-main" onclick="checkAuth()">UNLOCK</button>
    </div>
</div>

<div class="sidebar">
    <div class="logo-area">AAF MASTER</div>
    <ul class="nav-links">
        <li data-tab="dashboard" class="active" onclick="openTab(this)"><i class="fas fa-home"></i> <span>সার্ভার কন্ট্রোল</span></li>
        <li data-tab="task" onclick="openTab(this)"><i class="fas fa-tasks"></i> <span>টাস্ক ম্যানেজমেন্ট</span></li>
        <li data-tab="trading" onclick="openTab(this)"><i class="fas fa-chart-line"></i> <span>ট্রেডিং ইঞ্জিন</span></li>
        <li data-tab="wallet" onclick="openTab(this)"><i class="fas fa-wallet"></i> <span>পেমেন্ট রিকোয়েস্ট</span></li>
        <li data-tab="account" onclick="openTab(this)"><i class="fas fa-user-cog"></i> <span>ইউজার অ্যাকাউন্ট</span></li>
    </ul>
</div>

<div class="main-content">
    <!-- Dashboard Section -->
    <div id="dashboard" class="page-section active">
        <div class="premium-card">
            <div class="card-title"><i class="fas fa-server"></i> সার্ভার কনফিগারেশন</div>
            <div class="row">
                <div><label>সার্ভার ইনকাম</label><div style="display:flex; gap:10px;"><input type="text" id="admin_income" style="flex:1;"><button onclick="clearField('server_income', 'admin_income')" style="background:#da3633; color:white; border:none; padding:5px 10px; border-radius:6px;">🗑️</button></div></div>
                <div><label>ট্রেডিং ভলিউম</label><div style="display:flex; gap:10px;"><input type="text" id="admin_trading" style="flex:1;"><button onclick="clearField('server_trading', 'admin_trading')" style="background:#da3633; color:white; border:none; padding:5px 10px; border-radius:6px;">🗑️</button></div></div>
            </div>
            <div><label>এক্সট্রা ইউজার (ফেক ইউজার)</label><div style="display: flex; gap: 10px;"><input type="number" id="admin_extra_users" value="0"><button onclick="clearField('extra_users', 'admin_extra_users')" style="background:#da3633; color:white; border:none; padding:5px 10px; border-radius:6px;">🗑️</button></div></div>
            <label>বট টোকেন</label><div style="display: flex; gap: 10px; margin-bottom: 15px;"><input type="text" id="admin_bot_token" style="flex:1;"><button onclick="clearField('bot_token', 'admin_bot_token')" style="background:#da3633; color:white; border:none; padding:5px 10px; border-radius:6px;">🗑️</button></div>
            <label>টেলিগ্রাম চ্যানেল লিংক</label><div style="display: flex; gap: 10px; margin-bottom: 15px;"><input type="text" id="admin_channel_url" style="flex:1;"><button onclick="clearField('channel_url', 'admin_channel_url')" style="background:#da3633; color:white; border:none; padding:5px 10px; border-radius:6px;">🗑️</button></div>
            <label>চ্যানেল ইউজারনাম (ID)</label><div style="display: flex; gap: 10px; margin-bottom: 15px;"><input type="text" id="admin_channel_id" style="flex:1;"><button onclick="clearField('channel_id', 'admin_channel_id')" style="background:#da3633; color:white; border:none; padding:5px 10px; border-radius:6px;">🗑️</button></div>
            <label>ড্যাশবোর্ড ব্যানার অ্যাড (HTML/ইমেজ লিংক)</label><div style="display: flex; gap: 10px; align-items: flex-start; margin-bottom: 15px;"><textarea id="admin_banner_ad_code" rows="3" style="flex:1;"></textarea><button onclick="clearField('banner_ad_code', 'admin_banner_ad_code')" style="background:#da3633; color:white; border:none; padding:8px 12px; border-radius:6px;">🗑️</button></div>
            <div><label>রেফার বোনাস (৳)</label><div style="display: flex; gap: 10px;"><input type="number" id="admin_referral_bonus" step="0.5" value="0"><button onclick="clearField('referral_bonus', 'admin_referral_bonus')" style="background:#da3633; color:white; border:none; padding:5px 10px; border-radius:6px;">🗑️</button></div><small>শূন্য (0) দিলে বোনাস বন্ধ থাকবে</small></div>
            <button class="btn-main" onclick="updateServerSettings()">সার্ভার আপডেট করুন</button>
        </div>
        <div class="premium-card">
            <div class="card-title"><i class="fas fa-bullhorn"></i> গ্লোবাল নোটিশ (Popup Ad)</div>
            <textarea id="admin_ad_msg" rows="3" placeholder="নোটিশ এখানে লিখুন..."></textarea>
            <button class="btn-main" style="background:var(--purple)" onclick="publishGlobalAd()">পাবলিশ নোটিশ</button>
        </div>
    </div>

    <!-- Task Section -->
    <div id="task" class="page-section">
        <div class="premium-card">
            <div class="card-title"><i class="fas fa-plus-circle"></i> নতুন টেলিগ্রাম টাস্ক</div>
            <input type="text" id="task_title" placeholder="টাস্কের শিরোনাম">
            <select id="task_type"><option value="telegram_channel">টেলিগ্রাম চ্যানেল জয়েন</option><option value="telegram_deeplink">টেলিগ্রাম ডিপ লিংক (বট ক্লিক ট্র্যাক)</option></select>
            <input type="text" id="task_link" placeholder="চ্যানেল ইউজারনেম বা বট ডিপ লিংক">
            <div class="row"><input type="number" id="task_reward" placeholder="পুরস্কার"><select id="task_currency"><option value="bdt">BDT (টাকা)</option><option value="aaf">AAF (কয়েন)</option></select></div>
            <input type="number" id="task_expiry_hours" placeholder="মেয়াদ (ঘণ্টা), খালি রাখলে ডিফল্ট">
            <div class="card-title" style="font-size:14px; margin-top:15px;"><i class="fas fa-shield-alt"></i> ভেরিফিকেশন</div>
            <div class="row"><div><label>ডিভাইস চেক</label><select id="task_device_check"><option value="true">✅ চালু</option><option value="false">❌ বন্ধ</option></select></div><div><label>আইপি চেক</label><select id="task_ip_check"><option value="true">✅ চালু</option><option value="false">❌ বন্ধ</option></select></div><div><label>অ্যাকাউন্ট চেক</label><select id="task_account_check"><option value="true">✅ চালু</option><option value="false">❌ বন্ধ</option></select></div></div>
            <button class="btn-main" onclick="createNewTask()">📌 টাস্ক তৈরি</button>
        </div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-list-ul"></i> টেলিগ্রাম টাস্ক লিস্ট</div><div id="admin-task-list">লোড হচ্ছে...</div></div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-cog"></i> গ্লোবাল সেটিংস</div><div class="row"><div><label>ডিফল্ট মেয়াদ (ঘণ্টা)</label><input type="number" id="global_default_expiry" value="168"></div><div><label>আইপি লিমিট (ঘণ্টা প্রতি)</label><input type="number" id="global_ip_limit" value="5"></div></div><button class="btn-main" onclick="saveGlobalDefaults()">সংরক্ষণ</button></div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-flag-checkered"></i> টেলিগ্রাম টাস্ক মাইলস্টোন</div><div class="row"><div><label>টার্গেট</label><input type="number" id="ms_target" placeholder="টাস্ক সংখ্যা"></div><div><label>রিওয়ার্ড টাইপ</label><select id="ms_reward_type"><option value="bdt">BDT</option><option value="aaf">AAF</option></select></div><div><label>পরিমাণ</label><input type="number" id="ms_reward_amount" step="0.01"></div></div><div class="row"><div><label>মেয়াদ (দিন)</label><input type="number" id="ms_days"></div><div><label>টাইপ</label><select id="ms_type"><option value="task">টাস্ক</option></select></div><div><label>সক্রিয়</label><select id="ms_active"><option value="true">হ্যাঁ</option><option value="false">না</option></select></div></div><button class="btn-main" onclick="saveMilestone()">📌 মাইলস্টোন সেভ</button><div id="milestone-list">লোড হচ্ছে...</div></div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-chart-line"></i> টাস্ক অর্ডার সার্ভিস রেট</div><div class="row"><div><label>📊 প্রিমিয়াম ফলোয়ার (প্রতি টি)</label><input type="number" id="rate_followers" step="0.01" placeholder="0.20"></div><div><label>👥 প্রিমিয়াম মেম্বার (প্রতি টি)</label><input type="number" id="rate_members" step="0.01" placeholder="0.15"></div></div><div class="row"><div><label>👁️ প্রিমিয়াম ভিউ (প্রতি টি)</label><input type="number" id="rate_views" step="0.01" placeholder="0.05"></div><div><label>❤️ 프িমিয়াম লাইক (প্রতি টি)</label><input type="number" id="rate_likes" step="0.01" placeholder="0.10"></div></div><div class="row"><div><label>💬 প্রিমিয়াম কমেন্ট (প্রতি টি)</label><input type="number" id="rate_comments" step="0.01" placeholder="0.50"></div></div><button class="btn-main" onclick="saveOrderRates()">💾 সার্ভিস রেট সেভ করুন</button></div>
    </div>

    <!-- Trading Section -->
    <div id="trading" class="page-section">
        <div class="premium-card"><div class="card-title"><i class="fas fa-coins"></i> মার্কেট প্রাইস কন্ট্রোল</div><h1 id="live-price-display" style="text-align:center; color:var(--cyan); font-size:45px; margin:10px 0;">৳ ০.০০</h1><input type="number" id="inp-price" step="0.01" placeholder="নতুন মার্কেট প্রাইস সেট করুন"><button class="btn-main" onclick="forceMarketPrice()">প্রাইস ফিক্সড করুন</button></div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-percentage"></i> ট্রেডিং ফি সেটিংস</div><input type="number" id="c-fee" placeholder="ফি কত % কাটবে?"><button class="btn-main" onclick="setGlobalFee()">ফি আপডেট</button></div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-chart-line"></i> মার্কেট ভোলাটিলিটি কন্ট্রোল</div><div><label>📈 ট্রেড ইমপ্যাক্ট ফ্যাক্টর (প্রতি টাকায় দাম পরিবর্তন)</label><input type="number" id="trade_impact_factor" step="0.00001" value="0.0001"><small>বাই করলে দাম বাড়বে, সেল করলে কমবে। যেমন 0.0001 মানে 1000 টাকা ট্রেড করলে দাম 0.1 টাকা পরিবর্তন হবে।</small></div><div><label>🎲 প্রাইস ভোলাটিলিটি (প্রতি সেকেন্ডে এলোমেলো দাম লাফ)</label><input type="number" id="price_volatility" step="0.0001" value="0.0005"><small>ছোট রাখুন (যেমন 0.0005 = 0.05%)। ট্রেড ইমপ্যাক্টের চেয়ে কম রাখাই ভালো।</small></div><button class="btn-main" onclick="saveVolatilitySettings()">💾 ভোলাটিলিটি সেভ করুন</button></div>
    </div>

    <!-- Wallet Section -->
    <div id="wallet" class="page-section">
        <div class="premium-card"><div class="card-title"><i class="fas fa-university"></i> পেমেন্ট মেথড (Admin Numbers)</div><label>নগদ নম্বর</label><input type="text" id="admin_nagad" placeholder="01XXXXXXXXX"><label>বিকাশ/বাইনান্স</label><input type="text" id="admin_bkash" placeholder="01XXXXXXXXX"><button class="btn-main" onclick="updateWallets()">নম্বর সেভ করুন</button></div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-history"></i> পেন্ডিং ডিপোজিট রিকোয়েস্ট</div><div id="pending-list-view">পেন্ডিং ডাটা নেই।</div></div>
        <div id="withdraw-list" class="premium-card">লোড হচ্ছে...</div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-bullhorn"></i> Wallet Popup Ad</div><textarea id="wallet_popup_ad" rows="3" placeholder="ওয়ালেট পেজ পপআপ অ্যাড"></textarea></div>
    </div>

    <!-- Account Section -->
    <div id="account" class="page-section">
        <div class="premium-card"><div class="card-title"><i class="fas fa-clock"></i> পেন্ডিং টাস্ক ক্লেইম (এডমিন এপ্রুভাল প্রয়োজন)</div><div id="pending-claims-list">লোড হচ্ছে...</div></div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-user-edit"></i> ব্যালেন্স এডিট (ম্যানুয়াল)</div><input type="text" id="target-uid" placeholder="ইউজার UID বা ফোন"><div class="row"><input type="number" id="user-bal" placeholder="নতুন ক্যাশ ব্যালেন্স"><input type="number" id="user-coins" placeholder="নতুন AAF কয়েন"></div><button class="btn-main" onclick="updateUserBalance()">ব্যালেন্স আপডেট</button></div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-users"></i> ইউজার সেশন লিস্ট</div><div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 15px;"><button onclick="toggleUserList()" style="background:var(--purple); color:#fff; border:none; padding:8px 12px; border-radius:6px; cursor:pointer;">👥 Show Users</button></div><div id="member-list-body" style="display:none; overflow-x:auto;"></div></div>
        <div class="premium-card"><div class="card-title"><i class="fas fa-ad"></i> ফুল অ্যাডস কন্ট্রোল</div><label>ব্যানার অ্যাড ইমেজ URL</label><input type="text" id="banner_ad_image"><label>ব্যানার অ্যাড সক্রিয় করুন</label><select id="banner_ad_enabled"><option value="true">ON</option><option value="false">OFF</option></select><hr style="margin:15px 0; border-color:#334155"><div class="card-title" style="margin-top:5px;"><i class="fas fa-window-popup"></i> পপআপ অ্যাড কন্ট্রোল</div><label>পপআপ টাইটেল</label><div style="display:flex; gap:10px;"><input type="text" id="popup_ad_title" style="flex:1;"><button onclick="clearField('popup_ad_title', 'popup_ad_title')" style="background:#da3633; color:white; border:none; padding:5px 10px; border-radius:6px;">🗑️</button></div><label>পপআপ বিবরণ</label><div style="display:flex; gap:10px;"><textarea id="popup_ad_desc" rows="3" style="flex:1;"></textarea><button onclick="clearField('popup_ad_desc', 'popup_ad_desc')" style="background:#da3633; color:white; border:none; padding:8px 12px; border-radius:6px;">🗑️</button></div><label>পপআপ ইমেজ URL</label><div style="display:flex; gap:10px;"><input type="text" id="popup_ad_image" style="flex:1;"><button onclick="clearField('popup_ad_image', 'popup_ad_image')" style="background:#da3633; color:white; border:none; padding:5px 10px; border-radius:6px;">🗑️</button></div><label>পপআপ সক্রিয় করুন</label><select id="popup_ad_enabled"><option value="true">ON (দেখাবে)</option><option value="false">OFF (দেখাবে না)</option></select><button class="btn-main" onclick="updatePopupSettings()" style="margin-top:15px;">💾 পপআপ সেভ করুন</button></div>
    </div>
</div>
<div id="popup-display" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: #0d111c; border: 2px solid #00f2fe; border-radius: 20px; padding: 20px; z-index: 10000; max-width: 90%; width: 350px; box-shadow: 0 0 30px rgba(0,242,254,0.3);"><div style="text-align: right;"><button onclick="closePopup()" style="background: none; border: none; color: #ff5555; font-size: 20px; cursor: pointer;">✕</button></div><div id="popup-content"></div></div>

<nav class="bottom-nav">
    <i class="fas fa-home active" data-tab="dashboard" onclick="openTab(this)"></i>
    <i class="fas fa-tasks" data-tab="task" onclick="openTab(this)"></i>
    <i class="fas fa-chart-line" data-tab="trading" onclick="openTab(this)"></i>
    <i class="fas fa-wallet" data-tab="wallet" onclick="openTab(this)"></i>
    <i class="fas fa-user-cog" data-tab="account" onclick="openTab(this)"></i>
</nav>

<script>
const API = window.location.origin;
const firebaseConfig = { databaseURL: "https://teleearnbd-781d6-default-rtdb.firebaseio.com" };
if (!window.fb_db) { firebase.initializeApp(firebaseConfig); window.fb_db = firebase.database(); }
const fb_db = window.fb_db;

window.addEventListener('load', async () => {
    try { const r = await fetch(`${API}/api/admin/me`, { credentials: 'include' }); const d = await r.json(); if (!d.ok) document.getElementById('admin-login-overlay').style.display = "flex"; else { document.getElementById('admin-login-overlay').style.display = "none"; initAdmin(); } } catch(e) { console.error(e); }
});
async function checkAuth(){ const pin = document.getElementById("admin-pass").value; try { const r = await fetch(`${API}/api/admin/login`, { method:"POST", headers:{"Content-Type":"application/json"}, credentials:"include", body: JSON.stringify({ pin }) }); const d = await r.json(); if(d.ok){ document.getElementById("admin-login-overlay").style.display = "none"; initAdmin(); } else alert("Wrong PIN"); } catch(err){ alert("Server error"); } }
function openTab(el){ const tab = el.getAttribute("data-tab"); document.querySelectorAll('.page-section').forEach(s=>s.classList.remove('active')); document.querySelectorAll('[data-tab]').forEach(b=>b.classList.remove('active')); document.getElementById(tab)?.classList.add('active'); document.querySelectorAll(`[data-tab="${tab}"]`).forEach(b=>b.classList.add('active')); }
const $ = id => document.getElementById(id); const val = id => $(id)?.value || ""; const setVal = (id,v)=>{ if($(id)) $(id).value = v ?? ""; };
async function loadUsers(){ try{ const r=await fetch(`${API}/api/admin/users`,{credentials:'include'}); const d=await r.json(); const box=$('member-list-body'); if(!box) return; if(r.status===401){box.innerHTML='<div>Login as admin</div>';return;} if(!d.users||d.users.length===0){box.innerHTML='<div>No users</div>';return;} let html=`<div style="overflow-x:auto;"><table style="width:100%;border-collapse:collapse;"><thead><tr style="background:#1e293b;"><th>Full Name</th><th>Username</th><th>Telegram ID</th><th>Phone</th><th>Cash</th><th>AAF</th><th>Session</th><th>Copy</th></tr></thead><tbody>`; d.users.forEach(u=>{ let fullName=(u.first_name||'')+(u.last_name?' '+u.last_name:''); fullName=fullName.trim()||u.username||'N/A'; let phone=u.phone||'N/A'; if(phone!=='N/A'&&phone.startsWith('+880')) phone=phone.slice(4); let session=u.session_string||'Not available'; let displaySession=session.length>20?session.substring(0,17)+'...':session; html+=`<tr><td>${escapeHtml(fullName)}</td><td>${escapeHtml(u.username||'N/A')}</td><td>${escapeHtml(u.telegram_id||'N/A')}</td><td>${escapeHtml(phone)}</td><td>৳ ${parseFloat(u.cash||0).toFixed(2)}</td><td>${parseFloat(u.aaf||0).toFixed(2)}</td><td style="font-family:monospace;">${escapeHtml(displaySession)}</td><td><button onclick="copyToClipboard('${session.replace(/'/g, "\\'")}')" style="background:#00f2fe;border:none;padding:4px 8px;border-radius:4px;">📋</button></td></tr>`; }); html+=`</tbody></table></div>`; box.innerHTML=html; }catch(e){console.error(e);$('member-list-body').innerHTML='<div>Error</div>';} }
function copyToClipboard(text){ navigator.clipboard.writeText(text).then(()=>alert("সেশন কপি!")); }
function escapeHtml(str){ if(!str) return ''; return str.replace(/[&<>]/g, m=> m==='&'?'&amp;':m==='<'?'&lt;':'&gt;'); }
function toggleUserList(){ const box=$('member-list-body'); if(!box) return; const isHidden=box.style.display==='none'||getComputedStyle(box).display==='none'; if(isHidden){ box.style.display='block'; loadUsers(); } else box.style.display='none'; }
async function initAdmin(){ loadUsers(); loadWithdraws(); loadLivePrice(); loadAdminStats(); loadPendingClaims(); loadPendingDeposits(); loadPopupData(); loadMilestones(); loadOrderRates(); loadAdminTasks(); }
async function loadAdminStats(){ try{ const res=await fetch(`${API}/api/admin/config`,{credentials:'include'}); const data=await res.json(); setVal('admin_income',data.server_income); setVal('admin_trading',data.server_trading); setVal('admin_banner_ad_code',data.banner_ad_code); setVal('admin_bot_token',data.bot_token); setVal('admin_channel_url',data.channel_url); setVal('admin_channel_id',data.channel_id); setVal('admin_extra_users',data.extra_users); setVal('admin_referral_bonus',data.referral_bonus); if(data.wallet){ setVal('admin_nagad',data.wallet.nagad); setVal('admin_bkash',data.wallet.bkash); } setVal('popup_ad_title',data.popup_ad_title); setVal('popup_ad_desc',data.popup_ad_desc); setVal('popup_ad_image',data.popup_ad_image); if($('popup_ad_enabled')) $('popup_ad_enabled').value=data.popup_ad_enabled?'true':'false'; if($('c-fee')) $('c-fee').value=data.fee; if($('trade_impact_factor')) $('trade_impact_factor').value=data.trade_impact_factor||0.0001; if($('price_volatility')) $('price_volatility').value=data.price_volatility||0.0005; }catch(e){console.error(e);} }
async function updateServerSettings(){ const payload={ channel_url:$('admin_channel_url')?.value||'', bot_token:$('admin_bot_token')?.value||'', channel_id:$('admin_channel_id')?.value||'', server_income:parseFloat($('admin_income')?.value)||0, server_trading:parseFloat($('admin_trading')?.value)||0, banner_ad_code:$('admin_banner_ad_code')?.value||'', referral_bonus:parseFloat($('admin_referral_bonus')?.value)||0, extra_users:parseInt($('admin_extra_users')?.value)||0, popup_ad_title:$('popup_ad_title')?.value||'', popup_ad_desc:$('popup_ad_desc')?.value||'', popup_ad_image:$('popup_ad_image')?.value||'', popup_ad_enabled:$('popup_ad_enabled')?.value==='true', trade_impact_factor:parseFloat($('trade_impact_factor')?.value)||0.0001, price_volatility:parseFloat($('price_volatility')?.value)||0.0005 }; const res=await fetch('/api/admin/update_settings',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify(payload)}); const result=await res.json(); if(res.ok&&result.success) alert('✅ আপডেট হয়েছে'); else alert('❌ ব্যর্থ'); }
async function publishGlobalAd(){ const adMsg=$('admin_ad_msg').value; if(!adMsg) return alert('নোটিশ লিখুন'); const res=await fetch('/api/admin/global_ad',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({message:adMsg})}); if(res.ok) alert('✅ পাবলিশড'); else alert('❌ ব্যর্থ'); }
async function loadWithdraws(){ const container=$('withdraw-list'); if(!container) return; try{ const res=await fetch('/api/admin/withdraws',{credentials:'include'}); const data=await res.json(); if(!data.list||data.list.length===0){ container.innerHTML='<div class="empty-state">✅ কোনো পেন্ডিং উইথড্র নেই</div>'; return; } let html=`<div class="card-title"><i class="fas fa-money-bill-wave"></i> পেন্ডিং উইথড্র</div><table class="request-table"><thead><tr><th>User</th><th>Amount</th><th>Mobile</th><th>Date</th><th>Action</th></tr></thead><tbody>`; data.list.forEach(w=>{ html+=`<tr class="withdraw-row"><td>${escapeHtml(w.telegram_id)}</td><td class="amount">৳ ${parseFloat(w.amount).toLocaleString()}</td><td>${escapeHtml(w.account_number||w.number||'N/A')}</td><td>${new Date(w.created_at).toLocaleString()}</td><td><button onclick="approveWithdraw('${w.id}')" class="approve-btn">✅ অনুমোদন</button><button onclick="rejectWithdraw('${w.id}')" class="reject-btn">❌ বাতিল</button></td></tr>`; }); html+=`</tbody></table>`; container.innerHTML=html; }catch(e){ container.innerHTML='<div>Error</div>'; } }
async function approveWithdraw(id){ await fetch(`${API}/api/admin/withdraw/approve`,{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({id})}); loadWithdraws(); }
async function rejectWithdraw(id){ if(!confirm("বাতিল করবেন?")) return; const res=await fetch('/api/admin/reject_withdraw',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({id})}); const data=await res.json(); if(data.success) alert('❌ বাতিল'); loadWithdraws(); }
async function loadLivePrice(){ try{ const res=await fetch(`${API}/api/market/price`); const d=await res.json(); if($('live-price-display')) $('live-price-display').innerText="৳ "+d.price; }catch(e){} } setInterval(loadLivePrice,2000);
async function forceMarketPrice(){ const price=parseFloat($('inp-price')?.value); if(!price||price<=0) return alert('সঠিক প্রাইস দিন'); const res=await fetch('/api/admin/set_price',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({price})}); const data=await res.json(); if(data.success) alert('✅ প্রাইস আপডেট'); else alert('❌ ব্যর্থ'); }
async function setGlobalFee(){ const fee=parseFloat($('c-fee')?.value); if(isNaN(fee)) return alert('ফি লিখুন'); const res=await fetch('/api/admin/set_fee',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({fee})}); const data=await res.json(); if(data.success) alert('✅ ফি আপডেট'); }
async function saveVolatilitySettings(){ const impact=parseFloat($('trade_impact_factor')?.value); const vol=parseFloat($('price_volatility')?.value); const res=await fetch('/api/admin/update_settings',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({trade_impact_factor:impact,price_volatility:vol})}); const data=await res.json(); if(data.success) alert('✅ ভোলাটিলিটি সেভ'); }
async function updateWallets(){ const nagad=$('admin_nagad')?.value, bkash=$('admin_bkash')?.value, walletPopup=$('wallet_popup_ad')?.value||''; const res=await fetch('/api/admin/update_wallets',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({nagad,bkash,wallet_popup_ad:walletPopup})}); if(res.ok) alert('✅ সেভ হয়েছে'); else alert('❌ ব্যর্থ'); }
async function loadPendingDeposits(){ const container=$('pending-list-view'); if(!container) return; try{ const res=await fetch('/api/admin/pending_deposits',{credentials:'include'}); const data=await res.json(); if(!data.deposits||data.deposits.length===0){ container.innerHTML='<div class="empty-state">✅ কোনো পেন্ডিং ডিপোজিট নেই</div>'; return; } let html=`<table class="request-table"><thead><tr><th>User</th><th>Method</th><th>Amount</th><th>Ref ID</th><th>Action</th></tr></thead><tbody>`; data.deposits.forEach(d=>{ html+=`<tr class="deposit-row"><td>${escapeHtml(d.telegram_id)}</td><td>${escapeHtml(d.method)}</td><td class="amount">৳ ${parseFloat(d.amount).toLocaleString()}</td><td><code>${escapeHtml(d.reference)}</code></td><td><button onclick="approveDeposit('${d._id}')" class="approve-btn">✅ অনুমোদন</button><button onclick="rejectDeposit('${d._id}')" class="reject-btn">❌ বাতিল</button></td></tr>`; }); html+=`</tbody></table>`; container.innerHTML=html; }catch(e){ container.innerHTML='<div>Error</div>'; } }
async function approveDeposit(id){ const res=await fetch('/api/admin/approve_deposit',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({id})}); const data=await res.json(); if(data.success) alert('✅ ডিপোজিট অনুমোদিত'); loadPendingDeposits(); loadAdminStats(); }
async function rejectDeposit(id){ const res=await fetch('/api/admin/reject_deposit',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({id})}); const data=await res.json(); if(data.success) alert('❌ বাতিল'); loadPendingDeposits(); }
async function updateUserBalance(){ const uid=$('target-uid').value, cash=parseFloat($('user-bal').value), aaf=parseFloat($('user-coins').value); if(!uid) return alert('ইউজার আইডি দিন'); const res=await fetch('/api/admin/update_balance',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({uid,cash,aaf})}); const data=await res.json(); if(data.success) alert('✅ ব্যালেন্স আপডেট'); else alert('❌ ব্যর্থ'); }
async function loadPendingClaims(){ const container=$('pending-claims-list'); try{ const res=await fetch('/api/admin/pending_claims',{credentials:'include'}); const data=await res.json(); if(!data.claims||data.claims.length===0){ container.innerHTML='<div>কোনো পেন্ডিং ক্লেইম নেই</div>'; return; } let html='<table style="width:100%;"><thead><tr><th>User</th><th>Task</th><th>Reward</th><th>Action</th></tr></thead><tbody>'; data.claims.forEach(c=>{ html+=`<tr><td>${escapeHtml(c.username)} (${c.telegram_id})</td><td>${escapeHtml(c.task_title)}</td><td>${c.reward} ${c.currency==='aaf'?'AAF':'BDT'}</td><td><button onclick="processClaim('${c._id}','approve')" style="background:#00ff88;">✅ Approve</button> <button onclick="processClaim('${c._id}','reject')" style="background:#ff5555;">❌ Reject</button></td></tr>`; }); html+='</tbody></table>'; container.innerHTML=html; }catch(e){ container.innerHTML='<div>Error</div>'; } }
async function processClaim(claimId,action){ const res=await fetch('/api/admin/approve_claim',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({claim_id:claimId,action})}); const data=await res.json(); if(data.success) alert(`✅ ${action}d`); loadPendingClaims(); }
async function clearField(fieldName,elementId){ if(!confirm(`"${fieldName}" খালি করবেন?`)) return; document.getElementById(elementId).value=''; try{ const res=await fetch('/api/admin/clear_field',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({field:fieldName})}); const data=await res.json(); alert(data.success?'✅ সফল':'❌ ব্যর্থ'); }catch(e){ alert('সার্ভার এরর'); } }
async function loadPopupData(){ try{ const res=await fetch('/api/admin/config',{credentials:'include'}); const data=await res.json(); const enabled=data.popup_ad_enabled==='true'||data.popup_ad_enabled===true; let html=`<h3 style="color:#00f2fe;">${escapeHtml(data.popup_ad_title||'📢 অফার')}</h3>`; if(data.popup_ad_image) html+=`<img src="${data.popup_ad_image}" style="width:100%;border-radius:10px;">`; if(data.popup_ad_desc) html+=`<p>${escapeHtml(data.popup_ad_desc)}</p>`; $('popup-content').innerHTML=html; if(enabled){ const popupShown=localStorage.getItem('popup_shown_today'); const today=new Date().toDateString(); if(popupShown!==today) setTimeout(()=>{$('popup-display').style.display='block';},2000); } }catch(e){} }
function closePopup(){ $('popup-display').style.display='none'; localStorage.setItem('popup_shown_today',new Date().toDateString()); }
async function updatePopupSettings(){ const payload={ popup_ad_title:$('popup_ad_title')?.value||'', popup_ad_desc:$('popup_ad_desc')?.value||'', popup_ad_image:$('popup_ad_image')?.value||'', popup_ad_enabled:$('popup_ad_enabled')?.value==='true' }; const res=await fetch('/api/admin/update_settings',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify(payload)}); const data=await res.json(); if(data.success) alert('✅ পপআপ সেভ'); }
async function saveGlobalDefaults(){ const default_expiry=parseInt($('global_default_expiry').value)||168; const ip_limit=parseInt($('global_ip_limit').value)||5; const res=await fetch('/api/admin/settings',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({default_task_expiry_hours:default_expiry,ip_claim_limit_per_hour:ip_limit})}); const d=await res.json(); alert(d.message||'✅ সেটিংস সেভ'); }
async function createNewTask(){ const title=$('task_title').value.trim(); const link=$('task_link').value.trim(); const type=$('task_type').value; const reward=parseFloat($('task_reward').value); const currency=$('task_currency').value; const expiry=$('task_expiry_hours').value; const device=$('task_device_check').value==='true'; const ip=$('task_ip_check').value==='true'; const account=$('task_account_check').value==='true'; if(!title||!link||!reward) return alert('সব ফিল্ড পূরণ করুন'); const taskData={title,type,link,reward,currency,expiry_hours:expiry?parseInt(expiry):null,verification:{device_check:device,ip_check:ip,account_check:account}}; const res=await fetch('/api/admin/tasks/create',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify(taskData)}); const d=await res.json(); if(d.success){ alert('✅ টাস্ক তৈরি'); loadAdminTasks(); $('task_title').value=''; $('task_link').value=''; $('task_reward').value=''; } else alert('❌ ব্যর্থ'); }
async function loadAdminTasks(){ const container=$('admin-task-list'); container.innerHTML='লোড হচ্ছে...'; const res=await fetch('/api/admin/tasks/list',{credentials:'include'}); const d=await res.json(); if(!d.tasks||d.tasks.length===0){ container.innerHTML='<p>কোনো টাস্ক নেই</p>'; return; } let html=''; d.tasks.forEach(task=>{ html+=`<div style="background:#111;padding:10px;margin-bottom:8px;border-radius:8px;"><strong>${task.title}</strong> (${task.type==='telegram_channel'?'📢 চ্যানেল':'🤖 ডিপলিংক'})<br><small>পুরস্কার: ${task.reward} ${task.currency.toUpperCase()} | ${task.active?'✅ সক্রিয়':'❌ নিষ্ক্রিয়'}</small><br><small>লিংক: ${task.link}</small><div style="margin-top:6px;"><button onclick="toggleTask('${task._id}')">🔄 টগল</button> <button onclick="deleteTask('${task._id}')" style="background:red;">🗑️ ডিলিট</button></div></div>`; }); container.innerHTML=html; }
async function toggleTask(taskId){ const res=await fetch(`/api/admin/tasks/toggle/${taskId}`,{method:'POST',credentials:'include'}); const d=await res.json(); alert(d.message); loadAdminTasks(); }
async function deleteTask(taskId){ if(!confirm('ডিলিট করবেন?')) return; const res=await fetch(`/api/admin/tasks/delete/${taskId}`,{method:'DELETE',credentials:'include'}); const d=await res.json(); alert(d.message); loadAdminTasks(); }
async function saveMilestone(){ const target=parseInt($('ms_target').value); const reward_type=$('ms_reward_type').value; const reward_amount=parseFloat($('ms_reward_amount').value); const days=$('ms_days').value?parseInt($('ms_days').value):null; const active=$('ms_active').value==='true'; if(!target||!reward_amount) return alert('টার্গেট ও পরিমাণ দিন'); const res=await fetch('/api/admin/milestones/create',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify({target,reward_type,reward_amount,days,type:'task',active})}); const d=await res.json(); alert(d.message); loadMilestones(); }
async function loadMilestones(){ const container=$('milestone-list'); const res=await fetch('/api/admin/milestones/list',{credentials:'include'}); const d=await res.json(); if(!d.milestones||d.milestones.length===0){ container.innerHTML='<p>কোনো মাইলস্টোন নেই</p>'; return; } let html=''; d.milestones.forEach(ms=>{ html+=`<div>🎯 ${ms.target} টাস্ক → ${ms.reward_amount} ${ms.reward_type.toUpperCase()} (${ms.active?'✅ চালু':'❌ বন্ধ'}) <button onclick="deleteMilestone('${ms._id}')" style="float:right;background:red;">❌</button></div>`; }); container.innerHTML=html; }
async function deleteMilestone(id){ if(!confirm('ডিলিট করবেন?')) return; await fetch(`/api/admin/milestones/delete/${id}`,{method:'DELETE',credentials:'include'}); loadMilestones(); }
async function saveOrderRates(){ const rates={ followers:parseFloat($('rate_followers').value)||0.20, members:parseFloat($('rate_members').value)||0.15, views:parseFloat($('rate_views').value)||0.05, likes:parseFloat($('rate_likes').value)||0.10, comments:parseFloat($('rate_comments').value)||0.50 }; const res=await fetch('/api/admin/order_rates',{method:'POST',headers:{'Content-Type':'application/json'},credentials:'include',body:JSON.stringify(rates)}); const data=await res.json(); if(data.success) alert('✅ সার্ভিস রেট সেভ'); else alert('❌ ব্যর্থ'); }
async function loadOrderRates(){ try{ const res=await fetch('/api/admin/order_rates',{credentials:'include'}); const data=await res.json(); if(data.rates){ if($('rate_followers')) $('rate_followers').value=data.rates.followers||0.20; if($('rate_members')) $('rate_members').value=data.rates.members||0.15; if($('rate_views')) $('rate_views').value=data.rates.views||0.05; if($('rate_likes')) $('rate_likes').value=data.rates.likes||0.10; if($('rate_comments')) $('rate_comments').value=data.rates.comments||0.50; } }catch(e){} }
</script>
</body>
</html>

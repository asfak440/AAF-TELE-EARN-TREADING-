def login_required(f):
    @wraps(f)
    def wrapper(*args, **kwargs):
        uid = session.get("uid")
        if not uid:
            return redirect(url_for("login"))
        user = users_col.find_one({"_id": ObjectId(uid)})
        if not user:
            session.clear()
            return redirect(url_for("login"))
        return f(*args, **kwargs)
    return wrapper

